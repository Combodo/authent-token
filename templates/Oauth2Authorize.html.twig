{% UIFieldSet Standard { sLegend:'AuthentToken:Oauth2:Authorize:Title'|dict_s } %}
    {% UIForm Standard {sId:"oauth2_authorize_form"} %}
        {% UIField Small { sLabel:'AuthentToken:Oauth2:Authorize:Question'|dict_format(sApplication, sScope) } %}
            {% UIInput ForHidden { sName:'operation', sValue:'DoAuthorize' } %}
            {% UIInput ForHidden { sName:'transaction_id', sValue:sTransactionId } %}
            {% UIInput ForHidden { sName:'application_id', sValue:iApplicationId } %}
            {% UIInput ForHidden { sName:'state', sValue:sState } %}
            {% UIInput ForHidden { sName:'scope', sValue:sScope } %}

            {% UIButton ForSecondaryAction { sLabel:'AuthentToken:Oauth2:Authorize:ButtonCancel'|dict_s, sValue: 'disallow' , sName : 'decision', bIsSubmit:true } %}
            {% UIButton ForPrimaryAction { sLabel:'AuthentToken:Oauth2:Authorize:ButtonOk'|dict_s, sValue: 'allow' , sName : 'decision', bIsSubmit:true } %}
        {% EndUIField %}
    {% EndUIForm %}
{% EndUIFieldSet %}
